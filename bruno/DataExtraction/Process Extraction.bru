meta {
  name: "Process Extraction"
  type: "http"
  seq: 1
}

post {
  url: {{baseUrl}}/extract-data
  body: json
  auth: none
}

headers {
  X-Internal-Service-Key: {{internalApiKey}}
}

body:json {
  {
    "projectId": 211,
    "fileId": 1,
    "patient": {
      "firstName": "John",
      "lastName": "Doe"
    },
    "extractedIcdCodes": [
      {
        "code": "A01.1",
        "reason": "Found in document header"
      }
    ]
  }
}

vars:pre-request {
  internalApiKey: your-key-here
}
